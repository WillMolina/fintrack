# =============================================================
# Supabase — get these from your project dashboard:
# https://supabase.com/dashboard → Settings → API
# =============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================
# Webhook secret — set this to any random string.
# Use the same value in your Make.com HTTP module headers.
# Generate one: openssl rand -hex 32
# =============================================================
WEBHOOK_SECRET=change-me-to-a-random-string
